# =============================================================================
# fotoarchiv .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Local configuration (contains machine-specific paths)
# -----------------------------------------------------------------------------
config/settings.toml

# -----------------------------------------------------------------------------
# Derived database artifact (built from .toml/.md files by build_db.py)
# -----------------------------------------------------------------------------
catalog/catalog.db
catalog/catalog.db-shm
catalog/catalog.db-wal

# -----------------------------------------------------------------------------
# OS and editor noise
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# -----------------------------------------------------------------------------
# Datasette
# -----------------------------------------------------------------------------
.datasette/

# -----------------------------------------------------------------------------
# Temporary and log files
# -----------------------------------------------------------------------------
*.log
*.tmp
reports/
